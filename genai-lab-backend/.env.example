# ==========================================================
# GenAI Lab — Environment Variables
# ==========================================================
# SETUP INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your actual values in .env
#   3. NEVER commit .env to Git — it contains secrets
#   4. .env is already in .gitignore
#
# Docker Compose automatically loads .env from the same directory.
# All ${VARIABLE:-default} references in docker-compose.yml
# resolve against these values.
# ==========================================================

# ----------------------------------------------------------
# DATABASE
# ----------------------------------------------------------
DB_NAME=genailab
DB_USERNAME=genailab
DB_PASSWORD=genailab_dev_password
DB_PORT=5432

# ----------------------------------------------------------
# MINIO — Object Storage
# ----------------------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_dev_password
MINIO_BUCKET=genailab-documents
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ----------------------------------------------------------
# OPENAI — AI Provider
# ----------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
# This is the only secret that has no default — you must provide it.
OPENAI_API_KEY=sk-your-openai-api-key-here

# ----------------------------------------------------------
# JWT — Authentication
# ----------------------------------------------------------
# Generate a strong secret: openssl rand -base64 64
# Must be at least 32 characters for HS256 algorithm.
JWT_SECRET=your-very-long-and-random-jwt-secret-key-change-this-in-production
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ----------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------
SERVER_PORT=8080
PROMETHEUS_PORT=9090
