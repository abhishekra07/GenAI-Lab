# ==========================================================
# Git Ignore — GenAI Lab Backend
# ==========================================================

# ----------------------------------------------------------
# SECRETS — NEVER COMMIT THESE
# ----------------------------------------------------------
.env
*.env.local

# ----------------------------------------------------------
# Maven build output
# ----------------------------------------------------------
target/
*/target/
!.mvn/wrapper/maven-wrapper.jar

# ----------------------------------------------------------
# IDE files
# ----------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.code-workspace

# ----------------------------------------------------------
# OS files
# ----------------------------------------------------------
.DS_Store
Thumbs.db

# ----------------------------------------------------------
# Local file uploads (if using local storage provider)
# ----------------------------------------------------------
uploads/

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
*.log
logs/

# ----------------------------------------------------------
# Docker — don't ignore docker-compose.yml but ignore overrides
# ----------------------------------------------------------
docker-compose.override.yml
application-dev-local.yml
**/application-dev-local.yml